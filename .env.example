# Copper account the running server operates as
COPPER_API_KEY=
COPPER_USER_EMAIL=
COPPER_USER_ID=

# Separate sandbox account used ONLY by the smoke tests (npm run smoke) — production is never mutated
COPPER_SANDBOX_API_KEY=
COPPER_SANDBOX_USER_EMAIL=
COPPER_SANDBOX_USER_ID=

# OAuth for the remote MCP endpoint. Auth is enforced ONLY when all three are set (unset = open).
# Paste the same CLIENT_ID / CLIENT_SECRET into the Claude connector's OAuth fields.
# JWT_SECRET is server-only (signs tokens) — never share it.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_JWT_SECRET=
# Optional: pin the public issuer URL (else derived from request headers, which works on Cloud Run)
# OAUTH_ISSUER=https://your-service-abc123.run.app
# Optional: extra allowed OAuth redirect hosts, comma-separated (claude.ai/claude.com/chatgpt.com already allowed)
# OAUTH_ALLOWED_REDIRECT_HOSTS=
